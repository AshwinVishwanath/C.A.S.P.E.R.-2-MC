{
  "name": "casper-mc",
  "private": true,
  "version": "0.1.0-beta.1",
  "main": "./out/main/index.js",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "dev": "node scripts/dev.js",
    "build": "electron-vite build",
    "build:icon": "node scripts/build-icon.js",
    "preview": "node scripts/dev.js --preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "dist": "npm run build:icon && npm run build && electron-builder --win portable --x64"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^33.4.11",
    "electron-builder": "^24.0.0",
    "electron-vite": "^5.0.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "build": {
    "appId": "com.casper.mc",
    "productName": "Casper Mission Control",
    "copyright": "Copyright (c) 2026 Ashwin Vishwanath",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "portable": {
      "artifactName": "casper-mc-${version}-portable.exe"
    }
  }
}
